# =============================================================================
#  AI Publisher Pro — Production Configuration
#  Copy to .env and fill in your values: cp .env.production .env
# =============================================================================

# ─── REQUIRED: At least ONE AI API key ────────────────────────────────────────
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Get from: https://ai.google.dev/
GOOGLE_API_KEY=

# Get from: https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# ─── REQUIRED: Security ──────────────────────────────────────────────────────
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=CHANGE_ME

# Environment: development | internal | production
SECURITY_MODE=production

# Enable authentication (required for production)
SESSION_AUTH_ENABLED=true
SESSION_BACKEND=file
SESSION_TIMEOUT_HOURS=8

# CSRF protection (recommended for internet-facing)
CSRF_ENABLED=true
CSRF_SECRET_KEY=CHANGE_ME

# CORS origins (comma-separated, your domain)
CORS_ORIGINS=https://yourdomain.com

# ─── OPTIONAL: Ports ─────────────────────────────────────────────────────────
BACKEND_PORT=3000
FRONTEND_PORT=3001

# ─── OPTIONAL: AI Settings ───────────────────────────────────────────────────
# Default AI provider: anthropic | openai | google | deepseek
PROVIDER=anthropic
MODEL=claude-sonnet-4-20250514
QUALITY_MODE=balanced

# Max concurrent AI calls
CONCURRENCY=5
MAX_CONCURRENT_JOBS=10

# ─── OPTIONAL: Limits ────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50
RATE_LIMIT=60/minute
AUTH_RATE_LIMIT=5/minute

# ─── OPTIONAL: Features ──────────────────────────────────────────────────────
CACHE_ENABLED=true
CHUNK_CACHE_ENABLED=true
CHECKPOINT_ENABLED=true
STREAMING_ENABLED=true
TM_ENABLED=true
GLOSSARY_ENABLED=true
QUALITY_VALIDATION=true

# ─── OPTIONAL: Budget ────────────────────────────────────────────────────────
# Daily AI spend limit in USD (0 = unlimited)
BUDGET_LIMIT_DAILY_USD=0

# ─── OPTIONAL: Logging ───────────────────────────────────────────────────────
# LOG_LEVEL=INFO
