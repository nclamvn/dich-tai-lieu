# =============================================================================
# Security Settings (P0 — MUST configure before production deployment)
# =============================================================================

# Environment: development | internal | production
SECURITY_MODE=development

# Session secret — MUST change in production!
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=INSECURE-DEV-SECRET-CHANGE-IN-PRODUCTION

# Session backend: memory (dev) | file (persists across restarts)
SESSION_BACKEND=memory
SESSION_FILE_PATH=data/sessions.json

# Session timeout in hours
SESSION_TIMEOUT_HOURS=8

# Enable session auth (required for production)
SESSION_AUTH_ENABLED=false

# CSRF secret — MUST change if CSRF is enabled
CSRF_SECRET_KEY=INSECURE-DEV-CSRF-CHANGE-IN-PRODUCTION
CSRF_ENABLED=false

# CORS origins (comma-separated). Empty = dev defaults (localhost:*)
# Production example: CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
CORS_ORIGINS=

# Rate limiting for auth endpoints (prevent brute force)
AUTH_RATE_LIMIT=5/minute

# =============================================================================
# API Keys
# =============================================================================
OPENAI_API_KEY=sk-your-openai-api-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
DEEPSEEK_OCR_API_KEY=your-deepseek-ocr-key-here

# Translation Config
PROVIDER=openai
MODEL=gpt-4o-mini
QUALITY_MODE=balanced
CONCURRENCY=4

# Chunk Settings
CHUNK_SIZE=3000
CONTEXT_WINDOW=500
MAX_RETRIES=5
RETRY_DELAY=3

# File Upload Limits
MAX_UPLOAD_SIZE_MB=50
MAX_OCR_IMAGE_SIZE_MB=10

# Rate Limiting
# Format: "number/period" (e.g., "60/minute", "100/hour", "1000/day")
RATE_LIMIT=60/minute

# Feature Flags
CACHE_ENABLED=true
QUALITY_VALIDATION=true
QUALITY_THRESHOLD=0.7
GLOSSARY_ENABLED=true
GLOSSARY_NAME=default

# Phase 5.1: Chunk Cache (Translation Layer Caching)
CHUNK_CACHE_ENABLED=true
CHUNK_CACHE_TTL_DAYS=30

# Phase 5.2: Checkpoints (Fault-Tolerant Resume)
CHECKPOINT_ENABLED=true
CHECKPOINT_INTERVAL=10

# Phase 5.4: Multi-Format Streaming Pipeline (Memory Optimization + Live Preview)
# Supports DOCX, PDF, and TXT formats with incremental building
STREAMING_ENABLED=true
STREAMING_BATCH_SIZE=100
STREAMING_BROADCAST_CHUNKS=true
STREAMING_PARTIAL_EXPORT=true
STREAMING_MEMORY_LIMIT_MB=500

# Export Settings
EXPORT_FORMAT=docx
EXPORT_ADD_HEADER=true
EXPORT_ADD_FOOTER=true
EXPORT_ADD_PAGE_NUMBERS=true
EXPORT_WATERMARK=false
EXPORT_WATERMARK_TEXT=DRAFT

# OCR Settings (Hybrid System - optional)
# MathPix API (for formula-specialized OCR)
MATHPIX_APP_ID=your-mathpix-app-id
MATHPIX_APP_KEY=your-mathpix-app-key

# PaddleOCR Settings (local OCR, no API key needed)
PADDLE_LANG=en
OCR_BACKEND=auto

# Deprecated (will be removed)
# DEEPSEEK_OCR_API_URL=
# DEEPSEEK_OCR_API_KEY=

# PDF Processing
POPPLER_PATH=

# ============================================================================
# BOOK-TO-CINEMA: VIDEO AI PROVIDERS
# ============================================================================

# ---------- Google Veo 2 (Recommended - Google Ecosystem) ----------
# Get from: https://console.cloud.google.com
# 1. Enable Vertex AI API
# 2. Create service account with Vertex AI User role
# 3. Download JSON key file
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
VEO_LOCATION=us-central1

# ---------- Replicate (Alternative/Fallback) ----------
# Get from: https://replicate.com/account/api-tokens
# Supports: minimax/video-01, hunyuan-video, stable-video-diffusion
REPLICATE_API_TOKEN=r8_your-replicate-api-token-here

# ---------- Runway Gen-3 (Future Support) ----------
# Get from: https://runwayml.com/api
# RUNWAY_API_KEY=your-runway-api-key-here

# ============================================================================
# CINEMA PIPELINE SETTINGS
# ============================================================================

# Default video provider: veo, replicate
CINEMA_DEFAULT_PROVIDER=veo

# Minimum video duration per scene (seconds)
CINEMA_MIN_VIDEO_DURATION=30

# Maximum concurrent video renders
CINEMA_MAX_CONCURRENT_RENDERS=3

# Output directory for cinema jobs
CINEMA_OUTPUT_DIR=outputs/cinema

# Default style: blockbuster, anime, noir, documentary, fantasy, horror, romantic
CINEMA_DEFAULT_STYLE=blockbuster

