# =============================================================================
# Docker Ignore File — AI Publisher Pro
# =============================================================================

# Git
.git
.gitignore

# Python caches
__pycache__
*.py[cod]
*$py.class
*.so
.mypy_cache/
.pytest_cache/
.coverage
htmlcov/
.ruff_cache/

# Virtual environments
env/
venv/
.venv/

# IDE
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Tests (not needed in production image)
tests/
pytest.ini

# Documentation
docs/
*.md
!README.md

# Frontend (backend image doesn't need it)
frontend/

# Data and outputs (mounted as volumes)
data/
outputs/
output/
uploads/
logs/
backups/

# Development files
*.log
*.tmp
*.bak
*.deprecated
.env.local
.env.development

# Large files
*.pdf
*.docx
*.zip
*.tar.gz

# Docker meta (not needed inside container)
Dockerfile*
docker-compose*.yml
.dockerignore

# CI/CD
.github/
.claude/

# Scripts (not needed in container)
scripts/
